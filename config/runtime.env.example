# Supply through AIDP job environment variables or a secret-backed scope.
OCI_STREAM_ENDPOINT=https://cell-1.streaming.ap-hyderabad-1.oci.oraclecloud.com
OCI_STREAM_OCID=ocid1.stream.oc1.ap-hyderabad-1.amaaaaaau6bxbdqaafv72eqqoktlxaidtkt33rfvsfxerhrj5g6i6xytinbq
OCI_CONFIG_FILE=/Workspace/config/config
OCI_PROFILE=DEFAULT
# Oracle AIDP Master Catalog / standard catalog for this project.
AIDP_CATALOG=aidp_poc
CONSUMER_GROUP=meter_bronze_consumer_v1
# Comma-separated OCI Streaming partition IDs. Set every partition in your stream.
OCI_STREAM_PARTITIONS=0
LATE_ARRIVAL_HOURS=48
# Optional producer controls. Leave INTERVAL_START_UTC unset for the current interval.
METER_COUNT=10000
# INTERVAL_START_UTC=2026-07-19T10:00:00+00:00
